datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  sindico
  morador
}

model Condominio {
  id                    Int               @id @default(autoincrement())
  nome                  String
  cnpjPix               String            @map("cnpj_pix")
  responsavel           String?
  textoPadraoCobranca   String?           @map("texto_padrao_cobranca")
  textoPadraoFundoObras String?           @map("texto_padrao_fundo_obras")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  apartamentos     Apartamento[]
  cobrancasMensais CobrancaMensal[]
  prestacoes       PrestacaoContas[]
  usuarios         Usuario[]

  @@map("condominios")
}

model Usuario {
  id            Int      @id @default(autoincrement())
  condominioId  Int      @map("condominio_id")
  nome          String
  email         String   @unique
  senha         String   // Guardará o hash criptografado da senha
  role          Role     @default(morador)
  apartamentoNo String?  @map("apartamento_no") // Ex: "101", "102" (Opcional se for síndico)
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  condominio    Condominio @relation(fields: [condominioId], references: [id])

  @@map("usuarios")
}

model Apartamento {
  id           Int      @id @default(autoincrement())
  condominioId Int      @map("condominio_id")
  numero       String
  morador      String?
  proprietario String?
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  condominio    Condominio     @relation(fields: [condominioId], references: [id])
  cobrancaItens CobrancaItem[]

  @@unique([condominioId, numero])
  @@map("apartamentos")
}

model CobrancaMensal {
  id                    Int            @id @default(autoincrement())
  condominioId          Int            @map("condominio_id")
  mesReferencia         String         @map("mes_referencia") // formato: "2026-06"
  dataVencimento        DateTime       @map("data_vencimento")
  taxaCondominioPadrao  Decimal        @db.Decimal(10, 2) @map("taxa_condominio_padrao")
  taxaExtraPadrao       Decimal        @db.Decimal(10, 2) @default(0.00) @map("taxa_extra_padrao")
  precoGasM3Padrao      Decimal        @db.Decimal(10, 2) @map("preco_gas_m3_padrao")
  observacoes           String?
  status                String         @default("aberta") // aberta, fechada
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  condominio Condominio     @relation(fields: [condominioId], references: [id])
  itens      CobrancaItem[]

  @@unique([condominioId, mesReferencia])
  @@map("cobrancas_mensais")
}

model CobrancaItem {
  id                 Int       @id @default(autoincrement())
  cobrancaMensalId   Int       @map("cobranca_mensal_id")
  apartamentoId      Int       @map("apartamento_id")
  taxaCondominio     Decimal   @db.Decimal(10, 2) @map("taxa_condominio")
  taxaExtra          Decimal   @db.Decimal(10, 2) @default(0.00) @map("taxa_extra")
  leituraAnteriorGas Decimal   @db.Decimal(10, 2) @default(0.00) @map("leitura_anterior_gas")
  leituraAtualGas    Decimal   @db.Decimal(10, 2) @default(0.00) @map("leitura_atual_gas")
  consumoGas         Decimal   @db.Decimal(10, 2) @default(0.00) @map("consumo_gas")
  precoGasM3         Decimal   @db.Decimal(10, 2) @default(0.00) @map("preco_gas_m3")
  valorGas           Decimal   @db.Decimal(10, 2) @default(0.00) @map("valor_gas")
  totalAPagar        Decimal   @db.Decimal(10, 2) @default(0.00) @map("total_a_pagar")
  valorPago          Decimal   @db.Decimal(10, 2) @default(0.00) @map("valor_pago")
  statusPagamento    String    @default("pendente") @map("status_pagamento") // pendente, pago
  dataPagamento      DateTime? @map("data_pagamento")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  cobrancaMensal CobrancaMensal @relation(fields: [cobrancaMensalId], references: [id], onDelete: Cascade)
  apartamento    Apartamento    @relation(fields: [apartamentoId], references: [id])

  @@unique([cobrancaMensalId, apartamentoId])
  @@map("cobranca_itens")
}

model PrestacaoContas {
  id                 Int                    @id @default(autoincrement())
  condominioId       Int                    @map("condominio_id")
  mesReferencia      String                 @map("mes_referencia") // formato: "2026-06"
  saldoMesAnterior   Decimal                @db.Decimal(10, 2) @default(0.00) @map("saldo_mes_anterior")
  totalReceitas      Decimal                @db.Decimal(10, 2) @default(0.00) @map("total_receitas")
  totalDespesas      Decimal                @db.Decimal(10, 2) @default(0.00) @map("total_despesas")
  creditoMes         Decimal                @db.Decimal(10, 2) @default(0.00) @map("credito_mes")
  totalAtrasos       Decimal                @db.Decimal(10, 2) @default(0.00) @map("total_atrasos")
  saldoReservaGas    Decimal                @db.Decimal(10, 2) @default(0.00) @map("saldo_reserva_gas")
  saldoContaCorrente Decimal                @db.Decimal(10, 2) @default(0.00) @map("saldo_conta_corrente")
  saldoPoupanca      Decimal                @db.Decimal(10, 2) @default(0.00) @map("saldo_poupanca")
  status             String                 @default("aberta") // aberta, fechada
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  condominio    Condominio               @relation(fields: [condominioId], references: [id])
  receitas      Receita[]
  despesas      Despesa[]
  movimentacoes MovimentacaoFinanceira[]
  atrasos       Atraso[]
  creditos      Credito[]

  @@unique([condominioId, mesReferencia])
  @@map("prestacoes_contas")
}

model Receita {
  id                Int      @id @default(autoincrement())
  prestacaoContasId Int      @map("prestacao_contas_id")
  descricao         String
  valor             Decimal  @db.Decimal(10, 2)
  origem            String   @default("manual") // manual, cobranca, inadimplencia
  createdAt         DateTime @default(now()) @map("created_at")

  prestacaoContas PrestacaoContas @relation(fields: [prestacaoContasId], references: [id], onDelete: Cascade)

  @@map("receitas")
}

model Despesa {
  id                Int      @id @default(autoincrement())
  prestacaoContasId Int      @map("prestacao_contas_id")
  descricao         String
  categoria         String?  // energia, agua, servico, banco, manutencao
  valor             Decimal  @db.Decimal(10, 2)
  dataPagamento     String?  @map("data_pagamento")
  createdAt         DateTime @default(now()) @map("created_at")

  prestacaoContas PrestacaoContas @relation(fields: [prestacaoContasId], references: [id], onDelete: Cascade)

  @@map("despesas")
}

model MovimentacaoFinanceira {
  id                Int      @id @default(autoincrement())
  prestacaoContasId Int      @map("prestacao_contas_id")
  conta             String   // reserva_gas, conta_corrente, poupanca
  descricao         String
  valor             Decimal  @db.Decimal(10, 2)
  tipo              String   // entrada, saida, transferencia
  createdAt         DateTime @default(now()) @map("created_at")

  prestacaoContas PrestacaoContas @relation(fields: [prestacaoContasId], references: [id], onDelete: Cascade)

  @@map("movimentacoes_financeiras")
}

model Atraso {
  id                Int      @id @default(autoincrement())
  prestacaoContasId Int      @map("prestacao_contas_id")
  mesReferencia     String   @map("mes_referencia")
  valor             Decimal  @db.Decimal(10, 2)
  createdAt         DateTime @default(now()) @map("created_at")

  prestacaoContas PrestacaoContas @relation(fields: [prestacaoContasId], references: [id], onDelete: Cascade)

  @@map("atrasos")
}

model Credito {
  id                Int      @id @default(autoincrement())
  prestacaoContasId Int      @map("prestacao_contas_id")
  descricao         String
  valor             Decimal  @db.Decimal(10, 2)
  createdAt         DateTime @default(now()) @map("created_at")

  prestacaoContas PrestacaoContas @relation(fields: [prestacaoContasId], references: [id], onDelete: Cascade)

  @@map("creditos")
}